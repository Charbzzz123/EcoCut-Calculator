# Frontend / Angular
# Toggle Angular CLI analytics locally if desired
NG_CLI_ANALYTICS=false

# Server / NestJS
# Provide either GOOGLE_CALENDAR_CREDENTIALS (JSON content) or a path to a file.
# The JSON must contain client_email and private_key for the Google service account.
GOOGLE_CALENDAR_CREDENTIALS_PATH=./secrets/google-calendar.json
GOOGLE_CALENDAR_CREDENTIALS=
GOOGLE_CALENDAR_ID=ecojcut@gmail.com

# Entries persistence (Nest server)
# ENTRIES_DB_PATH controls the SQLite file location used for durable storage.
ENTRIES_DB_PATH=./server/data/entries.db
# ENTRIES_STORE_PATH is kept for backward compatibility with the previous JSON snapshot.
